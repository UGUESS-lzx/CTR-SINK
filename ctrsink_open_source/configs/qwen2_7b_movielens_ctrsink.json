{
  "backbone": "Qwen/Qwen2-7B",
  "tuning_method": "lora",
  "model_dtype": "bf16",
  "use_split_layer": true,
  "use_retrieval": true,
  "use_sink": true,
  "sink_signal": "temporal",
  "sink_num_embeddings": 100,
  "sink_embedding_dim": 256,
  "two_stage": true,
  "stage1_epochs": 3,
  "stage2_epochs": 3,
  "batch_size": 1,
  "eval_batch_size": 1,
  "gradient_accumulation_steps": 16,
  "lr": 1e-5,
  "precision": "bf16",
  "gradient_checkpointing": true,
  "max_user_tokens": 512,
  "max_item_tokens": 32,
  "num_behaviors": 50
}
